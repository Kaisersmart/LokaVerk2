<%- include('partials/header') %>
<main>

    <section class="featured">

        <h1>Add Character</h1>
        <form action="/characters/new" method="POST" class="character-form">

            <label for="name">Name</label>
            <input type="text" name="name" id="name" required>
            <label for="race">Race</label>
            <input type="text" name="race" id="race" required>

            <label for="homeland">Homeland</label>
            <input type="text" name="homeland" id="homeland" required>

            <label for="weapon">Weapon</label>
            <input type="text" name="weapon" id="weapon" required>

            <button type="submit">
                Add Character
            </button>

        </form>

    </section>
</main>
<%- include('partials/footer') %>